<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Test Suite" parallel="false">
    <test name="Smoke Tests - Login and Product Page">
        <classes>
            <!-- Login Tests -->
            <class name="com.saucedemo.tests.LoginPageTest">
                <methods>
                    <include name="testSuccessfulLogin"/>
                </methods>
            </class>
            
            <!-- Products Page Tests -->
            <class name="com.saucedemo.tests.ProductsPageTest">
                <methods>
                    <include name="testProductsPageDisplay"/>
                    <include name="testProductsAreListed"/>
                </methods>
            </class>
            
            <!-- Product Details Tests -->
            <class name="com.saucedemo.tests.ProductDetailsPageTest">
                <methods>
                    <include name="testProductNameIsDisplayed"/>
                </methods>
            </class>
            
            <!-- User Tests - Quick validation -->
            <class name="com.saucedemo.tests.user.StandardUserTest">
                <methods>
                    <include name="testStandardUserLogin"/>
                </methods>
            </class>
            <class name="com.saucedemo.tests.user.LockedOutUserTest">
                <methods>
                    <include name="testLockedOutUserCannotLogin"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
