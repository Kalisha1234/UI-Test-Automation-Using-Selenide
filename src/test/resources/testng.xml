<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="UI Test Automation Suite" parallel="false">
    <test name="User-Specific Tests">
        <classes>
            <class name="com.saucedemo.tests.user.StandardUserTest"/>
            <class name="com.saucedemo.tests.user.LockedOutUserTest"/>
            <class name="com.saucedemo.tests.user.ProblemUserTest"/>
            <class name="com.saucedemo.tests.user.PerformanceGlitchUserTest"/>
            <class name="com.saucedemo.tests.user.ErrorUserTest"/>
            <class name="com.saucedemo.tests.user.VisualUserTest"/>
        </classes>
    </test>
    <test name="Login Tests">
        <classes>
            <class name="com.saucedemo.tests.LoginPageTest"/>
        </classes>
    </test>
    <test name="Products Tests">
        <classes>
            <class name="com.saucedemo.tests.ProductsPageTest"/>
            <class name="com.saucedemo.tests.ProductDetailsPageTest"/>
        </classes>
    </test>
    <test name="Cart and Checkout Tests">
        <classes>
            <class name="com.saucedemo.tests.CartPageTest"/>
            <class name="com.saucedemo.tests.CheckoutPageTest"/>
        </classes>
    </test>
</suite>
